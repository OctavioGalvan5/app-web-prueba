        "responseBody": "={{ JSON.stringify({ \n  success: true, \n  response: $json.output, \n  user_id: $('Set Query').first().json.user_id \n}) }}",
        "options": {}
      },
      "id": "respond-chat",
      "name": "Respond Chat",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [-32, 352]
