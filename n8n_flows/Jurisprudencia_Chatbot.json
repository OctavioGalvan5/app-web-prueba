          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "name": "buscar_jurisprudencia",
        "description": "Busca sentencias judiciales relevantes en la base de datos. Usa esta herramienta para encontrar jurisprudencia sobre temas específicos, jueces, tribunales o palabras clave.",
        "returnType": "string"
      },
      "id": "retriever-tool",
      "name": "Retriever Tool",
      "type": "@n8n/n8n-nodes-langchain.toolRetriever",
      "typeVersion": 1,
      "position": [-48, 592]
    },
    {
      "parameters": {
